{
  "name": "csharp-lsp-cli",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "Single-request CLI bridge to a long-lived C# LSP daemon.",
  "bin": {
    "csharp-lsp-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "skill"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:fake": "vitest run tests/fake-lsp",
    "test:real": "vitest run tests/real-lsp",
    "smoke:pack": "npm run build && npm test && npm pack --json"
  },
  "dependencies": {
    "vscode-jsonrpc": "9.0.0",
    "vscode-languageserver-protocol": "3.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
